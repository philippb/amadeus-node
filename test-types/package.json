{
  "name": "amadeus-type-tests",
  "version": "1.0.0",
  "private": true,
  "description": "TypeScript definition tests for Amadeus Node SDK",
  "scripts": {
    "test:types": "tsc --noEmit",
    "test:compilation": "tsc --noEmit --project tsconfig.json",
    "test:dtslint": "dtslint .",
    "test:runtime": "jest runtime-compatibility.test.js",
    "test:all": "npm run test:compilation && npm run test:runtime",
    "type-check": "tsc --noEmit --strict"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^18.0.0",
    "dtslint": "^4.2.1",
    "jest": "^29.5.0",
    "typescript": "^5.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/*.test.js"],
    "verbose": true
  }
}